# ---------------------------------------
# Root HTML produced by accidental local renders
# (the site is built in _site/ via Actions)
# ---------------------------------------
/*.html
*.html
!/include_footer.html
!scripts/airplane_boarding/airplane_boarding.html
# Standalone JS app pages (hand-authored, must be tracked/deployed)
!/wc-momentum/index.html

# SEO files (keep these tracked)
!/robots.txt
!/sitemap.xml
